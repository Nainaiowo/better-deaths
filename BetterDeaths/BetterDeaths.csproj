<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Dalamud.NET.Sdk/15.0.0">
  <PropertyGroup>
    <Version>0.1.0.172</Version>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Platforms>x64</Platforms>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <IsPackable>false</IsPackable>
    <PackageProjectUrl>https://github.com/Nainaiowo/better-deaths</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>
  <Target Name="ValidateDalamudPackageManifest" AfterTargets="Build" DependsOnTargets="DefaultDalamudPackagerDebug;DefaultDalamudPackagerRelease">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;&amp; '$(MSBuildProjectDirectory)\..\scripts\validate-package-manifest.ps1' -ProjectDir '$(MSBuildProjectDirectory)' -OutputPath '$(OutputPath)' -AssemblyName '$(AssemblyName)'&quot;" />
  </Target>
</Project>
